<UserControl x:Class="WpfApp1.UserControls.DataSelectUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfApp1.ViewModel"
             Background="#1E5C1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="22"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="工位" FontSize="10" FontWeight="Bold" Margin="2"/>
            <TextBlock Grid.Column="1" Text="总数" FontSize="10" FontWeight="Bold" Margin="2"/>
            <TextBlock Grid.Column="2" Text="合格" FontSize="10" FontWeight="Bold" Margin="2" Foreground="#00FF00"/>
            <TextBlock Grid.Column="3" Text="不合格" FontSize="10" FontWeight="Bold" Margin="2" Foreground="Red"/>
            <TextBlock Grid.Column="4" Text="合格率" FontSize="10" FontWeight="Bold" Margin="2"/>
            <TextBlock Grid.Column="5" Text="AI" FontSize="10" FontWeight="Bold" Margin="2"/>
            <TextBlock Grid.Column="6" Text="跳" FontSize="10" FontWeight="Bold" Margin="2"/>
        </Grid>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Cameras}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Height="22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="10" Margin="2" VerticalAlignment="Center">
                            <Run Text="Cam"/><Run Text="{Binding CameraIndex, Converter={x:Static vm:IndexPlusOneConverter.Instance}}"/>
                        </TextBlock>
                        <TextBlock Grid.Column="1" Text="{Binding TotalCount}" FontSize="10" Margin="2" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding OKCount}" FontSize="10" Margin="2" VerticalAlignment="Center" Foreground="#00FF00"/>
                        <TextBlock Grid.Column="3" Text="{Binding NGCount}" FontSize="10" Margin="2" VerticalAlignment="Center" Foreground="Red"/>
                        <TextBlock Grid.Column="4" Text="{Binding PassRate}" FontSize="10" Margin="2" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="{Binding AiCount}" FontSize="10" Margin="2" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="{Binding SkipCount}" FontSize="10" Margin="2" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
