<UserControl x:Class="WpfApp1.UserControls.CheckSetUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E5C1E">
    <ScrollViewer>
        <StackPanel Margin="10">
            <!-- 保存按钮 -->
            <Button Content="保存" Style="{StaticResource GreenButton}" Width="80"
                    HorizontalAlignment="Left" Margin="0,0,0,8"
                    Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.SaveConfigCommand}"/>

            <!-- 通讯地址配置 -->
            <GroupBox Header="通讯地址配置" Margin="0,4">
                <StackPanel>
                    <Grid Margin="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="总数地址："/>
                        <TextBox Grid.Column="1" Text="{Binding TotalCountAddr}"/>
                        <TextBlock Grid.Column="2" Text="OK数地址：" Margin="8,0,0,0"/>
                        <TextBox Grid.Column="3" Text="{Binding OKCountAddr}"/>
                        <TextBlock Grid.Column="4" Text="NG数地址：" Margin="8,0,0,0"/>
                        <TextBox Grid.Column="5" Text="{Binding NGCountAddr}"/>
                        <TextBlock Grid.Column="6" Text="数据类型：" Margin="8,0,0,0"/>
                        <ComboBox Grid.Column="7" SelectedItem="{Binding DataType}">
                            <ComboBoxItem Content="Int16"/>
                            <ComboBoxItem Content="Int32"/>
                        </ComboBox>
                    </Grid>
                    <Grid Margin="2,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="启动地址："/>
                        <TextBox Grid.Column="1" Text="{Binding StartAddr}"/>
                        <TextBlock Grid.Column="2" Text="清料地址：" Margin="8,0,0,0"/>
                        <TextBox Grid.Column="3" Text="{Binding ClearAddr}"/>
                    </Grid>
                    <!-- 相机地址表 -->
                    <DataGrid ItemsSource="{Binding Cameras}" AutoGenerateColumns="False"
                              Margin="0,4" Height="160">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="工位" Binding="{Binding DisplayName}" Width="45" IsReadOnly="True"/>
                            <DataGridTextColumn Header="First信号" Binding="{Binding FirstAddr}" Width="90"/>
                            <DataGridTextColumn Header="Start信号" Binding="{Binding StartAddr}" Width="90"/>
                            <DataGridTextColumn Header="Result地址" Binding="{Binding ResultAddr}" Width="90"/>
                            <DataGridCheckBoxColumn Header="在线" Binding="{Binding IsOnline}" Width="45"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </GroupBox>

            <!-- 存图设置 -->
            <GroupBox Header="存图设置" Margin="0,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="存图位置：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SaveImagePath}" Margin="4,4"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="选择位置" Style="{StaticResource GreenButton}"
                            Margin="4" Click="BtnSelectPath_Click"/>
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="4">
                        <TextBlock Text="存图天数：" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding SaveDays}" Width="50" Margin="4,0"/>
                        <CheckBox Content="保存OK图" IsChecked="{Binding SaveOK}" Margin="16,0,0,0" VerticalAlignment="Center"/>
                        <CheckBox Content="保存NG图" IsChecked="{Binding SaveNG}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <CheckBox Content="是否需要光度立体" IsChecked="{Binding UsePhotometricStereo}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 模拟模式 -->
            <GroupBox Header="模拟模式（无相机/PLC时测试用）" Margin="0,4">
                <StackPanel>
                    <CheckBox Content="启用模拟模式" IsChecked="{Binding SimulationMode}" Margin="4,4" VerticalAlignment="Center"/>
                    <ItemsControl ItemsSource="{Binding SimFolders}" Margin="2,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding CameraName}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Folder, UpdateSourceTrigger=PropertyChanged}" Margin="4,0"/>
                                    <Button Grid.Column="2" Content="选择" Style="{StaticResource GreenButton}"
                                            Margin="4,0" Tag="{Binding}" Click="BtnSelectSimFolder_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid Margin="2,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="触发间隔(ms)：" VerticalAlignment="Center" FontSize="10"/>
                        <TextBox Grid.Column="1" Text="{Binding SimulationIntervalMs}" Margin="4,0"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- 拍照延时设置 -->
            <GroupBox Header="拍照延时设置" Margin="0,4">
                <DataGrid ItemsSource="{Binding Cameras}" AutoGenerateColumns="False" Height="200">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="工位" Binding="{Binding DisplayName}" Width="45" IsReadOnly="True"/>
                        <DataGridTextColumn Header="延时拍照次数" Binding="{Binding DelayShots}" Width="90"/>
                        <DataGridTextColumn Header="检测拍照数量" Binding="{Binding TotalShots}" Width="90"/>
                        <DataGridTextColumn Header="拍照间隔(ms)" Binding="{Binding ShotInterval}" Width="90"/>
                        <DataGridTextColumn Header="工位名称" Binding="{Binding StationName}" Width="80"/>
                        <DataGridCheckBoxColumn Header="结束标志" Binding="{Binding EndFlag}" Width="60"/>
                        <DataGridCheckBoxColumn Header="旋转工位" Binding="{Binding IsRotation}" Width="60"/>
                        <DataGridCheckBoxColumn Header="单次运行" Binding="{Binding SingleRun}" Width="60"/>
                        <DataGridTextColumn Header="执行间隔(ms)" Binding="{Binding ExecuteInterval}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
