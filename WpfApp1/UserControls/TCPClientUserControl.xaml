<UserControl x:Class="WpfApp1.UserControls.TCPClientUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E5C1E">
    <GroupBox Header="通讯类型">
        <StackPanel>
            <Grid Margin="2,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="通讯类型：" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" SelectedItem="{Binding PLCType}" Margin="2">
                    <ComboBoxItem Content="S7"/>
                    <ComboBoxItem Content="Fins"/>
                </ComboBox>
                <TextBlock Grid.Column="2" Text="IP地址：" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBox Grid.Column="3" Text="{Binding IP}" Margin="2"/>
                <Button Grid.Column="4" Content="连接" Style="{StaticResource GreenButton}" Margin="4,2"
                        Command="{Binding ConnectCommand}"/>
                <Button Grid.Column="5" Content="断开" Style="{StaticResource GreenButton}" Margin="4,2"
                        Command="{Binding DisconnectCommand}"/>
            </Grid>
            <Grid Margin="2,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="端口号：" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Port}" Margin="2"/>
                <TextBlock Grid.Column="2" Text="状态：" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="3" Text="{Binding StatusText}" VerticalAlignment="Center" Margin="2"/>
            </Grid>
            <Grid Margin="2,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="地址：" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Text="{Binding Address}" Margin="2"/>
                <TextBlock Grid.Column="2" Text="值：" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBox Grid.Column="3" Text="{Binding Value}" Margin="2"/>
                <Button Grid.Column="4" Content="读" Style="{StaticResource GreenButton}" Margin="4,2"
                        Command="{Binding ReadCommand}"/>
                <Button Grid.Column="5" Content="写" Style="{StaticResource GreenButton}" Margin="4,2"
                        Command="{Binding WriteCommand}"/>
            </Grid>
        </StackPanel>
    </GroupBox>
</UserControl>
