<UserControl x:Class="WpfApp1.UserControls.MainImageShowUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfApp1.ViewModel"
             Background="#1E5C1E">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate x:Key="CameraTemplate" DataType="{x:Type vm:MainImageShowViewModel}">
            <Border BorderBrush="#3A8A3A" BorderThickness="1" Margin="2" Background="#0A3A0A">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="16"/>
                    </Grid.RowDefinitions>

                    <!-- 标题栏 -->
                    <Grid Grid.Row="0" Background="#2A7A2A">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Margin="4,2" FontSize="11" FontWeight="Bold">
                            <Run Text="Cam"/><Run Text="{Binding CameraIndex, Converter={x:Static vm:IndexPlusOneConverter.Instance}}"/>
                        </TextBlock>
                        <TextBlock Grid.Column="1" Text="{Binding StationName}" Margin="8,2" FontSize="11"/>
                        <TextBlock Grid.Column="2" Margin="4,2" FontSize="14" FontWeight="Bold"
                                   Text="{Binding ResultText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOK}" Value="True">
                                            <Setter Property="Foreground" Value="#00FF00"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsOK}" Value="False">
                                            <Setter Property="Foreground" Value="Red"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- 图像 -->
                    <Grid Grid.Row="1">
                        <Image Source="{Binding DisplayImage}" Stretch="Uniform"/>
                        <!-- 检测结果叠加 -->
                        <ItemsControl ItemsSource="{Binding DetectResults}" VerticalAlignment="Top" HorizontalAlignment="Left"
                                      Margin="2" Visibility="{Binding IsOK, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Info}" Foreground="Red" FontSize="10" Margin="0,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- 检测中遮罩 -->
                        <Border Background="#80000000"
                                Visibility="{Binding IsDetecting, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="检测中..." Foreground="Yellow" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- 离线遮罩 -->
                        <Border Background="#80333333"
                                Visibility="{Binding IsOnline, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                            <TextBlock Text="离线" Foreground="Gray" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- 底部信息 -->
                    <TextBlock Grid.Row="2" Text="{Binding ImageInfo}" FontSize="9"
                               Foreground="#AAAAAA" Margin="2,1" TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <UniformGrid x:Name="cameraGrid" Rows="2" Columns="3">
        <ContentControl ContentTemplate="{StaticResource CameraTemplate}" Content="{Binding Cameras[0]}"/>
        <ContentControl ContentTemplate="{StaticResource CameraTemplate}" Content="{Binding Cameras[1]}"/>
        <ContentControl ContentTemplate="{StaticResource CameraTemplate}" Content="{Binding Cameras[2]}"/>
        <ContentControl ContentTemplate="{StaticResource CameraTemplate}" Content="{Binding Cameras[3]}"/>
        <ContentControl ContentTemplate="{StaticResource CameraTemplate}" Content="{Binding Cameras[4]}"/>
        <ContentControl ContentTemplate="{StaticResource CameraTemplate}" Content="{Binding Cameras[5]}"/>
    </UniformGrid>
</UserControl>
