<UserControl x:Class="WpfApp1.UserControls.BrightnessUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E5C1E">
    <GroupBox Header="阶段亮度">
        <ItemsControl ItemsSource="{Binding Stages}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <GroupBox Header="{Binding StageName}" Margin="0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="背光：" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding BackLight, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>
                            <TextBlock Grid.Column="2" Text="环光：" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="3" Text="{Binding RingLight, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>
                            <TextBlock Grid.Column="4" Text="顶光：" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="5" Text="{Binding TopLight, UpdateSourceTrigger=PropertyChanged}" Margin="2"/>
                        </Grid>
                    </GroupBox>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </GroupBox>
</UserControl>
