<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 主色调 -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E5C1E"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#2A7A2A"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3A8A3A"/>
    <SolidColorBrush x:Key="TextBrush" Color="White"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#00CC00"/>
    <SolidColorBrush x:Key="OKBrush" Color="#00CC00"/>
    <SolidColorBrush x:Key="NGBrush" Color="Red"/>
    <SolidColorBrush x:Key="ButtonBrush" Color="#33AA33"/>
    <SolidColorBrush x:Key="StartButtonBrush" Color="#00BB00"/>
    <SolidColorBrush x:Key="StopButtonBrush" Color="#CC3333"/>

    <!-- 全局字体 -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="#2A7A2A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#3A8A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="2"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="#2A7A2A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#3A8A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Foreground="{TemplateBinding Foreground}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False" ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0" Margin="4,2"/>
                                            <Path Grid.Column="1" Data="M0,0 L4,4 L8,0 Z"
                                                  Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#33AA33"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Background" Value="#1A6A1A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="6,2,24,2"
                                          VerticalAlignment="Center"/>
                        <Popup x:Name="Popup" Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False"
                               PopupAnimation="Slide">
                            <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                <Border Background="#1A5A1A" BorderBrush="#3A8A3A" BorderThickness="1" CornerRadius="0,0,2,2">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#2A7A2A"/>
        <Setter Property="Padding" Value="6,4"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="#33AA33"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#44BB44"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#2A7A2A"/>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="#2A7A2A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#3A8A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="CaretBrush" Value="White"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- 标准按钮 -->
    <Style x:Key="GreenButton" TargetType="Button">
        <Setter Property="Background" Value="#33AA33"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#44BB44"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#44BB44"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#229922"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 开始按钮 -->
    <Style x:Key="StartButton" TargetType="Button" BasedOn="{StaticResource GreenButton}">
        <Setter Property="Background" Value="#00BB00"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="20,8"/>
    </Style>

    <!-- 停止按钮 -->
    <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource GreenButton}">
        <Setter Property="Background" Value="#CC3333"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="20,8"/>
    </Style>

    <!-- 触发按钮 -->
    <Style x:Key="TriggerButton" TargetType="Button" BasedOn="{StaticResource GreenButton}">
        <Setter Property="Background" Value="#336633"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <!-- GroupBox 样式 -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#3A8A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    <!-- DataGrid 样式 -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="#1E5C1E"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#3A8A3A"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#3A8A3A"/>
        <Setter Property="RowBackground" Value="#1E5C1E"/>
        <Setter Property="AlternatingRowBackground" Value="#2A6A2A"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="IsReadOnly" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="CanUserReorderColumns" Value="False"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#2A7A2A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#3A8A3A"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="2"/>
    </Style>

    <!-- Tab 样式 -->
    <Style TargetType="TabItem">
        <Setter Property="Background" Value="#2A7A2A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#3A8A3A"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Border" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,1,1,0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#33AA33"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#3A8A3A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="#1E5C1E"/>
        <Setter Property="BorderBrush" Value="#3A8A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ListBox 样式 -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="#0A3A0A"/>
        <Setter Property="BorderBrush" Value="#3A8A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="#3A8A3A" BorderThickness="0,0,0,1" Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1A5A1A"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#33AA33"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DatePicker 样式 -->
    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="#2A7A2A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#3A8A3A"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="DatePickerTextBox">
        <Setter Property="Background" Value="#2A7A2A"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="SelectionBrush" Value="#44BB44"/>
    </Style>

    <!-- StatusBar 样式 -->
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="#155015"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <Style TargetType="StatusBarItem">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- ScrollBar 简化样式 -->
    <Style TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

</ResourceDictionary>
