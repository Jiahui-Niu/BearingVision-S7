<Window x:Class="WpfApp1.View.ReViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="图像回放" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#1E5C1E"
        Topmost="True">
    <DockPanel>
        <!-- 工具栏 -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,4" Background="#2A7A2A">
            <TextBlock Text="工位：" VerticalAlignment="Center" Margin="4,0"/>
            <ComboBox x:Name="cmbCamera" Width="100" SelectedIndex="0" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="全部"/>
                <ComboBoxItem Content="Cam1-内径1"/>
                <ComboBoxItem Content="Cam2-端面1"/>
                <ComboBoxItem Content="Cam3-端面2"/>
                <ComboBoxItem Content="Cam4-内径2"/>
                <ComboBoxItem Content="Cam5-外径1"/>
                <ComboBoxItem Content="Cam6-外径2"/>
            </ComboBox>
            <TextBlock Text="  日期：" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <DatePicker x:Name="dpStart" SelectedDate="{x:Null}" Width="110" Margin="4,0"
                        SelectedDateChanged="Filter_Changed"/>
            <TextBlock Text="至" VerticalAlignment="Center"/>
            <DatePicker x:Name="dpEnd" SelectedDate="{x:Null}" Width="110" Margin="4,0"
                        SelectedDateChanged="Filter_Changed"/>
            <TextBlock Text="  结果：" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <ComboBox x:Name="cmbResult" Width="80" SelectedIndex="0" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="全部"/>
                <ComboBoxItem Content="OK"/>
                <ComboBoxItem Content="NG"/>
            </ComboBox>
            <Button Content="查询" Style="{StaticResource GreenButton}" Margin="8,2" Click="BtnQuery_Click"/>
        </StackPanel>

        <!-- 底部状态 -->
        <StatusBar DockPanel.Dock="Bottom" Background="#155015">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="就绪" Foreground="White"/>
            </StatusBarItem>
        </StatusBar>

        <!-- 主体 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 图像列表 -->
            <ListBox x:Name="lstImages" Grid.Column="0" Background="#0A3A0A"
                     SelectionChanged="LstImages_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="{Binding Thumbnail}" Height="60" Stretch="Uniform"/>
                            <StackPanel Grid.Column="1" Margin="4,0">
                                <TextBlock Text="{Binding CameraName}" Foreground="White" FontSize="11"/>
                                <TextBlock Text="{Binding Timestamp}" Foreground="#AAAAAA" FontSize="10"/>
                                <TextBlock Text="{Binding ResultText}" FontSize="13" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOK}" Value="True">
                                                    <Setter Property="Foreground" Value="#00FF00"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsOK}" Value="False">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding DefectInfo}" Foreground="#FFAAAA" FontSize="10" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 大图显示 -->
            <Grid Grid.Column="1" Background="#0A3A0A">
                <Image x:Name="imgPreview" Stretch="Uniform" Margin="4"/>
                <TextBlock x:Name="txtNoImage" Text="请选择图像" Foreground="#666666"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"
                           Visibility="Visible"/>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
