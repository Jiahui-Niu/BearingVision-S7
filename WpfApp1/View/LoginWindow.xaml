<Window x:Class="WpfApp1.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="品晗视觉 - 登录" Height="280" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#1E5C1E" WindowStyle="SingleBorderWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="成品轴承外观机" FontSize="20" FontWeight="Bold"
                       Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="宁波品晗智能视觉" FontSize="12" Foreground="#AAFFAA"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 表单 -->
        <Grid Grid.Row="1" Margin="0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="用户名：" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbUser" Grid.Row="0" Grid.Column="1" Margin="0,4"
                      SelectedIndex="0">
                <ComboBoxItem Content="操作员"/>
                <ComboBoxItem Content="工程师"/>
                <ComboBoxItem Content="管理员"/>
            </ComboBox>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="密码：" VerticalAlignment="Center"/>
            <PasswordBox x:Name="pwdBox" Grid.Row="1" Grid.Column="1" Margin="0,4"
                         Background="#2A7A2A" Foreground="White" BorderBrush="#3A8A3A"
                         KeyDown="PwdBox_KeyDown"/>

            <TextBlock x:Name="txtError" Grid.Row="2" Grid.ColumnSpan="2"
                       Foreground="Red" Text="" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="登  录" Width="100" Height="34" Margin="10,0"
                    Style="{StaticResource GreenButton}" Click="BtnLogin_Click"/>
            <Button Content="跳过登录" Width="100" Height="34" Margin="10,0"
                    Style="{StaticResource GreenButton}" Click="BtnSkip_Click"/>
        </StackPanel>
    </Grid>
</Window>
