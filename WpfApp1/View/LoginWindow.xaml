<Window x:Class="WpfApp1.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="品晗视觉 - 登录" Height="300" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#1A4A1A" WindowStyle="SingleBorderWindow">
    <Grid>
        <!-- 顶部标题栏 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Border Grid.Row="0" Background="#155015">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="成品轴承外观机" FontSize="22" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="宁波品晗智能视觉" FontSize="11" Foreground="#88DD88"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- 表单 -->
        <Border Grid.Row="1" Margin="30,16,30,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="用户名："
                           VerticalAlignment="Center" FontSize="13" Foreground="White"/>
                <ComboBox x:Name="cmbUser" Grid.Row="0" Grid.Column="1"
                          SelectedIndex="0" Height="30" VerticalAlignment="Center"
                          FontSize="13">
                    <ComboBoxItem Content="操作员"/>
                    <ComboBoxItem Content="工程师"/>
                    <ComboBoxItem Content="管理员"/>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="密码："
                           VerticalAlignment="Center" FontSize="13" Foreground="White"/>
                <PasswordBox x:Name="pwdBox" Grid.Row="1" Grid.Column="1"
                             Height="30" VerticalAlignment="Center" FontSize="13"
                             KeyDown="PwdBox_KeyDown"/>

                <TextBlock x:Name="txtError" Grid.Row="2" Grid.ColumnSpan="2"
                           Foreground="#FF6666" Text="" VerticalAlignment="Center"
                           HorizontalAlignment="Center" FontSize="12"/>
            </Grid>
        </Border>

        <!-- 按钮 -->
        <Border Grid.Row="2" Background="#155015">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Content="登  录" Width="110" Height="36" Margin="12,0"
                        FontSize="14" FontWeight="Bold"
                        Style="{StaticResource GreenButton}" Click="BtnLogin_Click"/>
                <Button Content="跳过登录" Width="110" Height="36" Margin="12,0"
                        FontSize="13"
                        Style="{StaticResource GreenButton}" Click="BtnSkip_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
